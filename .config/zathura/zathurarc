# Zathura config
set default-bg                  "rgba(0, 0, 0, 0.60)"
set default-fg                  "#3B4252"

set statusbar-fg                "#F8F8F2"
set statusbar-bg                "#272822"

set inputbar-bg                 "#272822"
set inputbar-fg                 "#F4BF75"

set notification-bg             "#272822"
set notification-fg             "#F4BF75"

set notification-error-bg       "#272822"
set notification-error-fg       "#F8F8F2"

set notification-warning-bg     "#272822"
set notification-warning-fg     "#F8F8F2"

set highlight-color             "#EBCB8B"
set highlight-active-color      "#A1EFE4"

set completion-bg               "#272822"
set completion-fg               "#F92672"

set completion-highlight-fg     "#75715E"
set completion-highlight-bg     "#F4BF75"

# recolor-lightcolor Defines the color value that is used to represent light colors in recoloring mode
# recolor-darkcolor Defines the color value that is used to represent dark colors in recoloring mode
set recolor-lightcolor          "rgba(0, 0, 0, 0.60)"
set recolor-darkcolor           "rgba(255, 255, 255, 0.99)"

set guioptions none

set recolor-keephue             "true"
set recolor                     "true"

set smooth-scroll true
set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard

map i recolor
map xb toggle_statusbar
map K zoom in
map J zoom out
map L navigate next
map H navigate previous
map u scroll half-up
map d scroll half-down

set adjust-open width
