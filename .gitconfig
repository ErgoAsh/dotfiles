[init]
	defaultBranch = main
[user]
	email = ErgoAsh@users.noreply.github.com
[credential]
	credentialStore = gpg
	helper = /usr/local/share/gcm-core/git-credential-manager-core
[credential "https://dev.azure.com"]
	useHttpPath = true
[alias]
    tree = log --oneline --graph --all --decorate
[core]
	editor = /usr/bin/nvim
